{
  "name": "kv-searcher-bot",
  "version": "1.0.0",
  "description": "KV Searcher - Telegram bot wrapping the existing JSON searcher",
  "main": "electron.js",
  "scripts": {
    "start": "node bot.js",
    "desktop": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "telegraf": "^4.12.3",
    "stream-json": "^1.7.5"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.kvsearcher.bot",
    "productName": "KV Searcher Admin",
    "files": [
      "**/*"
    ],
    "win": {
      "target": ["nsis"]
    }
  }
}
